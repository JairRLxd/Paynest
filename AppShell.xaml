<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Paynest.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Paynest"
    xmlns:cobrador="clr-namespace:Paynest.Features.Cobrador.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light={StaticResource GreenPrimary}, Dark={StaticResource AppSurfaceDark}}"
    Shell.ForegroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource AppTextPrimaryDark}}"
    Shell.TitleColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource AppTextPrimaryDark}}"
    Shell.UnselectedColor="{AppThemeBinding Light={StaticResource TabBarInactiveLight}, Dark={StaticResource TabBarInactiveDark}}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light={StaticResource TabBarBgLight}, Dark={StaticResource TabBarBgDark}}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light={StaticResource TabBarActiveLight}, Dark={StaticResource TabBarActiveDark}}"
    Shell.TabBarTitleColor="{AppThemeBinding Light={StaticResource TabBarActiveLight}, Dark={StaticResource TabBarActiveDark}}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light={StaticResource TabBarInactiveLight}, Dark={StaticResource TabBarInactiveDark}}">

    <Shell.FlyoutHeader>
        <Grid
            Padding="20,28,20,18"
            RowDefinitions="Auto,Auto"
            RowSpacing="14"
            BackgroundColor="{AppThemeBinding Light={StaticResource AppBg}, Dark={StaticResource AppBgDark}}">
            <Grid ColumnDefinitions="52,*" ColumnSpacing="12">
                <Border
                    HeightRequest="52"
                    WidthRequest="52"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource AppSurfaceAlt}, Dark={StaticResource AppBorderDark}}">
                    <Image Source="paynest_icon.png" HeightRequest="34" WidthRequest="34" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label
                        Text="Paynest"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{AppThemeBinding Light={StaticResource AppTextPrimary}, Dark={StaticResource AppTextPrimaryDark}}" />
                    <Label
                        x:Name="FlyoutUserLabel"
                        Text="Cliente"
                        FontSize="13"
                        LineBreakMode="TailTruncation"
                        TextColor="{AppThemeBinding Light={StaticResource AppTextSecondary}, Dark={StaticResource AppTextSecondaryDark}}" />
                </VerticalStackLayout>
            </Grid>

            <Border
                Grid.Row="1"
                Padding="12,10"
                Stroke="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="{AppThemeBinding Light={StaticResource AppSurface}, Dark={StaticResource AppSurfaceDark}}">
                <VerticalStackLayout Spacing="3">
                    <Label
                        Text="Deuda activa"
                        FontSize="12"
                        TextColor="{AppThemeBinding Light={StaticResource AppTextSecondary}, Dark={StaticResource AppTextSecondaryDark}}" />
                    <Label
                        x:Name="FlyoutGroupLabel"
                        Text="Sin grupo seleccionado"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        LineBreakMode="TailTruncation"
                        TextColor="{AppThemeBinding Light={StaticResource AppTextPrimary}, Dark={StaticResource AppTextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Shell.FlyoutHeader>

    <TabBar x:Name="ClientTabBar" Route="client">
        <Tab Title="Inicio" Icon="tab_home.svg">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="main" />
        </Tab>
        <Tab Title="Calendario" Icon="tab_calendar.svg">
            <ShellContent ContentTemplate="{DataTemplate local:CalendarPage}" Route="calendar" />
        </Tab>
        <Tab Title="Recibos" Icon="tab_receipt.svg">
            <ShellContent ContentTemplate="{DataTemplate local:ReceiptsPage}" Route="receipts" />
        </Tab>
        <Tab Title="Saldo" Icon="tab_card.svg">
            <ShellContent ContentTemplate="{DataTemplate local:CardSimulatorPage}" Route="card" />
        </Tab>
    </TabBar>

    <TabBar x:Name="CollectorTabBar" Route="collector">
        <ShellContent
            Title="Inicio"
            Icon="tab_home.svg"
            Route="collector_home"
            ContentTemplate="{DataTemplate cobrador:HomePage}" />

        <ShellContent
            Title="Clientes"
            Icon="tab_clients.svg"
            Route="clients"
            ContentTemplate="{DataTemplate cobrador:ClientsPage}" />

        <ShellContent
            Title="Cobros"
            Icon="tab_collections.svg"
            Route="collections"
            ContentTemplate="{DataTemplate cobrador:CollectionsPage}" />

        <ShellContent
            Title="Agenda"
            Icon="tab_schedule.svg"
            Route="schedule"
            ContentTemplate="{DataTemplate cobrador:SchedulePage}" />

        <ShellContent
            Title="Perfil"
            Icon="tab_profile.svg"
            Route="profile"
            ContentTemplate="{DataTemplate cobrador:UserProfilePage}" />
    </TabBar>

    <MenuItem x:Name="SwitchGroupMenuItem" Text="Cambiar deuda activa" Clicked="OnSwitchGroupClicked" />
    <MenuItem x:Name="LinkCollectorMenuItem" Text="Vincular cobrador" Clicked="OnLinkCollectorClicked" />
    <MenuItem x:Name="NotificationsMenuItem" Text="Recordatorios" Clicked="OnNotificationsClicked" />
    <MenuItem Text="Cerrar sesión" Clicked="OnLogoutClicked" />

</Shell>
