<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Paynest.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:home="clr-namespace:Paynest.Features.Cobrador.Home.Views"
    xmlns:clients="clr-namespace:Paynest.Features.Cobrador.Clients.Views"
    xmlns:collections="clr-namespace:Paynest.Features.Cobrador.Collections.Views"
    xmlns:schedule="clr-namespace:Paynest.Features.Cobrador.Schedule.Views"
    xmlns:profile="clr-namespace:Paynest.Features.Cobrador.Profile.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarForegroundColor="#2A6349"
    Shell.TabBarUnselectedColor="#9E9E9E"
    Shell.TabBarTitleColor="#2A6349">

    <TabBar>

        <ShellContent
            Title="Inicio"
            Icon="tab_home.svg"
            Route="home"
            ContentTemplate="{DataTemplate home:HomePage}"/>

        <ShellContent
            Title="Clientes"
            Icon="tab_clients.svg"
            Route="clients"
            ContentTemplate="{DataTemplate clients:ClientsPage}"/>

        <ShellContent
            Title="Cobros"
            Icon="tab_collections.svg"
            Route="collections"
            ContentTemplate="{DataTemplate collections:CollectionsPage}"/>

        <ShellContent
            Title="Agenda"
            Icon="tab_schedule.svg"
            Route="schedule"
            ContentTemplate="{DataTemplate schedule:SchedulePage}"/>

        <ShellContent
            Title="Perfil"
            Icon="tab_profile.svg"
            Route="profile"
            ContentTemplate="{DataTemplate profile:UserProfilePage}"/>

    </TabBar>

</Shell>
