<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Profile.Views.UserProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource GreenPrimary}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,28,28"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto" Padding="24,52,24,24">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="End" Spacing="2">
                    <Label Text="Mi Perfil" FontFamily="OpenSansSemibold" FontSize="26"
                           TextColor="White"/>
                    <Label Text="Configuración y cuenta"
                           TextColor="#B8DCC9" FontSize="13"/>
                </VerticalStackLayout>
                <Image Grid.Column="1" Source="paynestletters.png" HeightRequest="22"
                       Aspect="AspectFit" VerticalOptions="Start" Opacity="0.7"/>
            </Grid>
        </Border>

        <VerticalStackLayout Grid.Row="1" Spacing="18" Padding="24,28,24,32">
            <Border BackgroundColor="White"
                    Stroke="#E2E8E4"
                    StrokeShape="RoundRectangle 22"
                    Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Cuenta de cobrador"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label x:Name="UserNameLabel"
                           Text="Cobrador"
                           FontSize="15"
                           TextColor="{StaticResource TextSecondary}"/>
                    <Label Text="Desde aquí puedes cerrar sesión de forma segura."
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           LineHeight="1.35"/>
                </VerticalStackLayout>
            </Border>

            <Button Text="Cerrar sesión"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FFF1F3"
                    BorderColor="#F04438"
                    BorderWidth="1.5"
                    TextColor="#D92D20"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    CornerRadius="24"
                    HeightRequest="54"/>

            <VerticalStackLayout VerticalOptions="CenterAndExpand" Spacing="12" Padding="8,30">
                <Label Text="👤" FontSize="52" HorizontalOptions="Center"/>
                <Label Text="Perfil en progreso" FontFamily="OpenSansSemibold" FontSize="20"
                       TextColor="{StaticResource GreenPrimary}" HorizontalOptions="Center"/>
                <Label Text="Aquí podrás ver tu perfil, métodos de pago y ajustes de cuenta."
                       TextColor="{StaticResource TextSecondary}" FontSize="14"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" LineHeight="1.4"/>
            </VerticalStackLayout>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
