<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Home.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Paynest.Features.Cobrador.Home.ViewModels"
    x:DataType="vm:HomeViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header verde ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource GreenPrimary}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,32,32"/>
            </Border.StrokeShape>
            <VerticalStackLayout Padding="24,52,24,20" Spacing="16">

                <!-- Saludo + campana -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="{Binding Greeting}" TextColor="#B8DCC9" FontSize="14"/>
                        <Label Text="{Binding UserName}" TextColor="White"
                               FontSize="26" FontFamily="OpenSansSemibold"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="#1F4F37" StrokeThickness="0"
                            StrokeShape="Ellipse" HeightRequest="42" WidthRequest="42"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NotificacionesCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="🔔" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Tarjetas de estadísticas -->
                <Grid ColumnDefinitions="*,10,*">
                    <Border Grid.Column="0" BackgroundColor="#1F4F37" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="14,12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="COBRADO HOY" TextColor="#B8DCC9"
                                   FontSize="11" CharacterSpacing="0.6"/>
                            <Label Text="{Binding CobradoHoy}" TextColor="White"
                                   FontSize="24" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding DeltaHoy}" TextColor="#B8DCC9" FontSize="12"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="#1F4F37" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="14,12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="ESTA SEMANA" TextColor="#B8DCC9"
                                   FontSize="11" CharacterSpacing="0.6"/>
                            <Label Text="{Binding EstaSemana}" TextColor="White"
                                   FontSize="24" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding MetaSemanal}" TextColor="#B8DCC9" FontSize="12"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ── Contenido scrollable ──────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- ── Acciones rápidas ───────────────────────────────── -->
                <Label Text="Acciones rápidas" FontFamily="OpenSansSemibold"
                       FontSize="16" TextColor="{StaticResource TextPrimary}"
                       Margin="0,0,0,12"/>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <!-- Nuevo cobro -->
                    <Border Grid.Column="0" BackgroundColor="{StaticResource GreenPrimary}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NuevoCobroCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="＋" TextColor="White" FontSize="22"
                                   FontFamily="OpenSansSemibold" HorizontalOptions="Center"/>
                            <Label Text="Nuevo cobro" TextColor="White" FontSize="11"
                                   FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Añadir cliente -->
                    <Border Grid.Column="1" BackgroundColor="#EBF5EF"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AnadirClienteCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="👤" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Añadir cliente" TextColor="{StaticResource TextPrimary}"
                                   FontSize="11" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Ticket -->
                    <Border Grid.Column="2" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TicketCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="📤" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Ticket" TextColor="{StaticResource TextPrimary}"
                                   FontSize="11" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Agenda -->
                    <Border Grid.Column="3" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerAgendaCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="🗓" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Agenda" TextColor="{StaticResource TextPrimary}"
                                   FontSize="11" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── Deudas activas ─────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,24,0,12">
                    <Label Grid.Column="0" Text="Deudas activas"
                           FontFamily="OpenSansSemibold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ver todas →"
                           TextColor="{StaticResource GreenAccent}" FontSize="14"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerDeudasCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Grid ColumnDefinitions="*,10,*">
                    <!-- Pendiente -->
                    <Border Grid.Column="0" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,12">
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="PENDIENTE" TextColor="{StaticResource TextSecondary}"
                                       FontSize="11" CharacterSpacing="0.5" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="⚠️" FontSize="16"/>
                            </Grid>
                            <Label Text="{Binding PendienteTotal}" TextColor="#E65100"
                                   FontSize="22" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding PendienteClientes}"
                                   TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Vencido -->
                    <Border Grid.Column="2" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,12">
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="VENCIDO" TextColor="{StaticResource TextSecondary}"
                                       FontSize="11" CharacterSpacing="0.5" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="🔺" FontSize="16"/>
                            </Grid>
                            <Label Text="{Binding VencidoTotal}" TextColor="{StaticResource Error}"
                                   FontSize="22" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding VencidoClientes}"
                                   TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── Próximas visitas ────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,24,0,12">
                    <Label Grid.Column="0" Text="Próximas visitas"
                           FontFamily="OpenSansSemibold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ver agenda →"
                           TextColor="{StaticResource GreenAccent}" FontSize="14"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerAgendaCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="18,16" Margin="0,0,0,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Sin visitas programadas"
                               FontFamily="OpenSansSemibold"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Cuando agenda tenga datos reales, aparecerán aquí."
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
