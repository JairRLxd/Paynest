<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Clients.AddClient.Views.AddClientPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Paynest.Features.Cobrador.Clients.AddClient.ViewModels"
    x:DataType="vm:AddClientViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Padding="24,52,24,20">
            <Grid ColumnDefinitions="40,*">
                <Border BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HeightRequest="40"
                        WidthRequest="40">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="‹"
                           FontSize="28"
                           TextColor="{StaticResource GreenPrimary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center">
                    <Label Text="CLIENTES"
                           FontSize="12"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource GreenPrimary}"/>
                    <Label Text="Añadir cliente"
                           FontSize="26"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,0,24,32" Spacing="18">

                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        Padding="0"
                        Shadow="0,12,24,#12000000">
                    <VerticalStackLayout Spacing="0">
                        <Grid BackgroundColor="{StaticResource GreenPrimary}"
                              Padding="24,22,24,24">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="TU CÓDIGO DE COBRADOR"
                                       HorizontalTextAlignment="Center"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="#B6D8C5"/>
                                <Label Text="{Binding CollectorCode}"
                                       HorizontalTextAlignment="Center"
                                       FontSize="36"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="White"/>
	                                <Label Text="Válido para todos tus clientes"
	                                       HorizontalTextAlignment="Center"
	                                       FontSize="14"
	                                       TextColor="#DDEFE5"/>
	                                <ActivityIndicator IsRunning="{Binding IsLoadingInvite}"
	                                                   IsVisible="{Binding IsLoadingInvite}"
	                                                   Color="White"
	                                                   HorizontalOptions="Center"/>
	                            </VerticalStackLayout>
	                        </Grid>

	                        <VerticalStackLayout Padding="18,18,18,20" Spacing="10">
	                            <Label Text="{Binding InviteStatusText}"
	                                   FontSize="12"
	                                   TextColor="{StaticResource TextSecondary}"
	                                   HorizontalTextAlignment="Center"
	                                   LineBreakMode="WordWrap"/>
	                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
	                                <Button Text="Copiar"
	                                        Command="{Binding CopyCodeCommand}"
	                                        BackgroundColor="White"
	                                        BorderColor="{StaticResource GreenPrimary}"
	                                        BorderWidth="2"
	                                        TextColor="{StaticResource GreenPrimary}"
	                                        FontFamily="OpenSansSemibold"
	                                        FontSize="15"
	                                        CornerRadius="18"
	                                        HeightRequest="54"/>
	                                <Button Grid.Column="1"
	                                        Text="Compartir"
	                                        Command="{Binding ShareCodeCommand}"
	                                        BackgroundColor="{StaticResource GreenPrimary}"
	                                        TextColor="White"
	                                        FontFamily="OpenSansSemibold"
	                                        FontSize="15"
	                                        CornerRadius="18"
	                                        HeightRequest="54"/>
	                            </Grid>
	                        </VerticalStackLayout>
	                    </VerticalStackLayout>
	                </Border>

                <Border BackgroundColor="White"
                        Stroke="#E7ECE8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24"
                        Padding="24,24,24,26">
                    <VerticalStackLayout Spacing="20">
                        <Label Text="O comparte el código QR"
                               HorizontalTextAlignment="Center"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"/>

                        <Border BackgroundColor="#F4F8F5"
                                Stroke="#DFE8E1"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                HorizontalOptions="Center"
                                HeightRequest="180"
                                WidthRequest="180"
                                Padding="14">
                            <Image Source="{Binding QrCodeImage}"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Label Text="Muestra este QR solo al cliente correcto para registrarlo contigo."
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="{StaticResource TextSecondary}"
                               LineHeight="1.35"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="14">
                    <Label Text="O registra manualmente"
                           FontSize="16"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"/>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nombre completo"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Border BackgroundColor="White"
                                Stroke="{StaticResource InputBorderBrush}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 16"
                                Padding="16,0">
                            <Entry Text="{Binding FullName}"
                                   Placeholder="Ej. María García"
                                   PlaceholderColor="{StaticResource TextPlaceholder}"
                                   HeightRequest="56"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Teléfono"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Border BackgroundColor="White"
                                Stroke="{StaticResource InputBorderBrush}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 16"
                                Padding="16,0">
                            <Entry Text="{Binding PhoneNumber}"
                                   Placeholder="Ej. 5512345678"
                                   PlaceholderColor="{StaticResource TextPlaceholder}"
                                   Keyboard="Telephone"
                                   HeightRequest="56"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Monto inicial"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Border BackgroundColor="White"
                                Stroke="{StaticResource InputBorderBrush}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 16"
                                Padding="16,0">
                            <Entry Text="{Binding Amount}"
                                   Placeholder="Ej. $500"
                                   PlaceholderColor="{StaticResource TextPlaceholder}"
                                   Keyboard="Numeric"
                                   HeightRequest="56"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Notas"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Border BackgroundColor="White"
                                Stroke="{StaticResource InputBorderBrush}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 16"
                                Padding="16,10">
                            <Editor Text="{Binding Notes}"
                                    Placeholder="Agrega una referencia breve para este cliente"
                                    PlaceholderColor="{StaticResource TextPlaceholder}"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="110"/>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Button Text="Registrar cliente"
                        Command="{Binding CreateClientCommand}"
                        BackgroundColor="{StaticResource GreenPrimary}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        CornerRadius="28"
                        HeightRequest="56"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
