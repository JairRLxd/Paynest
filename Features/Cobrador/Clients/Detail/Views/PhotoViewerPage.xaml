<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Clients.Detail.Views.PhotoViewerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="Black">

    <Grid>
        <!-- Imagen a pantalla completa -->
        <ScrollView x:Name="scrollView"
                    HorizontalScrollBarVisibility="Never"
                    VerticalScrollBarVisibility="Never">
            <Image x:Name="photoImage"
                   Aspect="AspectFit"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   MinimumHeightRequest="300"/>
        </ScrollView>

        <!-- Botón cerrar -->
        <Border BackgroundColor="#88000000"
                StrokeThickness="0"
                StrokeShape="Ellipse"
                HeightRequest="44" WidthRequest="44"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,52,20,0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseAsync"/>
            </Border.GestureRecognizers>
            <Label Text="✕" FontSize="18" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>
    </Grid>
</ContentPage>
