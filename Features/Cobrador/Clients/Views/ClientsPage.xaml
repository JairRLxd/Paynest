<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Clients.Views.ClientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Paynest.Features.Cobrador.Clients.ViewModels"
    xmlns:models="clr-namespace:Paynest.Features.Cobrador.Clients.Models"
    x:Name="ClientsRoot"
    x:DataType="vm:ClientsViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
              Padding="24,52,24,16">
            <Label Grid.Column="0" Text="Clientes"
                   FontFamily="OpenSansSemibold" FontSize="30"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center"/>
            <Border Grid.Column="1" BackgroundColor="{StaticResource GreenPrimary}"
                    StrokeThickness="0" StrokeShape="RoundRectangle 14"
                    HeightRequest="44" WidthRequest="44" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddClientCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="＋" TextColor="White" FontSize="22"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ── Barra de búsqueda ──────────────────────────────────────────── -->
        <Border Grid.Row="1" BackgroundColor="White"
                Stroke="#EBEBEB" StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                Margin="24,0,24,12" Padding="0">
            <Grid ColumnDefinitions="48,*" HeightRequest="46">
                <Label Grid.Column="0" Text="🔍" FontSize="17"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Entry Grid.Column="1" Text="{Binding SearchText}"
                       Placeholder="Buscar cliente..."
                       PlaceholderColor="{StaticResource TextPlaceholder}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- ── Filtros horizontales ───────────────────────────────────────── -->
        <ScrollView Grid.Row="2" Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Margin="24,0,0,14">
            <HorizontalStackLayout Spacing="8" Padding="0,0,24,0">

                <!-- Todos -->
                <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="16,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFilterCommand}" CommandParameter="Todos"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAllSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource GreenPrimary}"/>
                            <Setter Property="Stroke" Value="{StaticResource GreenPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAllSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="Stroke" Value="{StaticResource InputBorderBrush}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Todos" FontFamily="OpenSansSemibold" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAllSelected}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAllSelected}" Value="False">
                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Pendiente -->
                <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="16,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFilterCommand}" CommandParameter="Pendiente"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsPendienteSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource GreenPrimary}"/>
                            <Setter Property="Stroke" Value="{StaticResource GreenPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsPendienteSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="Stroke" Value="{StaticResource InputBorderBrush}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Pendiente" FontFamily="OpenSansSemibold" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPendienteSelected}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPendienteSelected}" Value="False">
                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Vencido -->
                <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="16,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFilterCommand}" CommandParameter="Vencido"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsVencidoSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource GreenPrimary}"/>
                            <Setter Property="Stroke" Value="{StaticResource GreenPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsVencidoSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="Stroke" Value="{StaticResource InputBorderBrush}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Vencido" FontFamily="OpenSansSemibold" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsVencidoSelected}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsVencidoSelected}" Value="False">
                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Al día -->
                <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="16,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFilterCommand}" CommandParameter="Al día"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAlDiaSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource GreenPrimary}"/>
                            <Setter Property="Stroke" Value="{StaticResource GreenPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAlDiaSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="Stroke" Value="{StaticResource InputBorderBrush}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Al día" FontFamily="OpenSansSemibold" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAlDiaSelected}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAlDiaSelected}" Value="False">
                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Parcial -->
                <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="16,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectFilterCommand}" CommandParameter="Parcial"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsParcialSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource GreenPrimary}"/>
                            <Setter Property="Stroke" Value="{StaticResource GreenPrimaryBrush}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsParcialSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="Stroke" Value="{StaticResource InputBorderBrush}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Parcial" FontFamily="OpenSansSemibold" FontSize="13">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsParcialSelected}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsParcialSelected}" Value="False">
                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource GreenPrimary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Start"
                           Margin="0,40,0,0"/>

        <!-- Estado vacío -->
        <VerticalStackLayout Grid.Row="3"
                             IsVisible="{Binding IsEmpty}"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             Spacing="8" Margin="0,40,0,0">
            <Label Text="Sin clientes registrados"
                   FontSize="14" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Agrega tu primer cliente con el botón ＋"
                   FontSize="12" TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- ── Lista de clientes ──────────────────────────────────────────── -->
        <ScrollView Grid.Row="3" IsVisible="{Binding HasClients}">
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Margin="24,0,24,24" Padding="0">

                <VerticalStackLayout
                    BindableLayout.ItemsSource="{Binding Clients}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:ClientSummary">

                            <VerticalStackLayout>
                                <!-- Separador (top de cada fila) -->
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Divider}"
                                         Margin="64,0,0,0"/>

                                <!-- Fila del cliente -->
                                <Grid ColumnDefinitions="64,*,Auto"
                                      Padding="14,12" ColumnSpacing="4">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference ClientsRoot}, Path=BindingContext.OpenClientDetailCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>

                                    <!-- Avatar -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{Binding AvatarColor}"
                                            StrokeThickness="0" StrokeShape="Ellipse"
                                            HeightRequest="40" WidthRequest="40"
                                            VerticalOptions="Center" HorizontalOptions="Start">
                                        <Label Text="{Binding Initials}"
                                               TextColor="White" FontSize="13"
                                               FontFamily="OpenSansSemibold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Nombre y fecha -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontFamily="OpenSansSemibold" FontSize="14"
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="{Binding DateText}"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="12"/>
                                    </VerticalStackLayout>

                                    <!-- Monto y estado -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="End" Spacing="4">
                                        <Label Text="{Binding Amount}"
                                               FontFamily="OpenSansSemibold" FontSize="14"
                                               TextColor="{StaticResource TextPrimary}"
                                               HorizontalTextAlignment="End"/>
                                        <Border BackgroundColor="{Binding StatusBgColor}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,3" HorizontalOptions="End">
                                            <Label Text="{Binding Status}"
                                                   TextColor="{Binding StatusTextColor}"
                                                   FontSize="11"
                                                   FontFamily="OpenSansSemibold"/>
                                        </Border>
                                    </VerticalStackLayout>

                                </Grid>
                            </VerticalStackLayout>

                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </Border>
        </ScrollView>

    </Grid>
</ContentPage>
