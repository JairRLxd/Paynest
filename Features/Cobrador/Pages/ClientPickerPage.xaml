<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Pages.ClientPickerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Paynest.Features.Cobrador.ViewModels"
    xmlns:models="clr-namespace:Paynest.Features.Cobrador.Models"
    x:Name="thisPage"
    x:DataType="vm:ClientPickerViewModel"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Encabezado ─────────────────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Padding="16,20,16,0" Spacing="14">

            <!-- Pastilla de arrastre -->
            <BoxView HeightRequest="4" WidthRequest="44" CornerRadius="2"
                     BackgroundColor="#D1D5DB" HorizontalOptions="Center"/>

            <!-- Título + cerrar -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Seleccionar cliente"
                       FontFamily="OpenSansSemibold" FontSize="22"
                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                <Border Grid.Column="1"
                        BackgroundColor="#F3F4F6" StrokeThickness="0"
                        StrokeShape="Ellipse"
                        HeightRequest="36" WidthRequest="36"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DismissCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="✕" FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

        </VerticalStackLayout>

        <!-- ── Buscador ───────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Stroke="{StaticResource InputBorderBrush}"
                StrokeShape="RoundRectangle 14" StrokeThickness="1.5"
                BackgroundColor="{StaticResource White}"
                HeightRequest="50" Margin="16,14,16,6">
            <Grid ColumnDefinitions="Auto,*" Margin="14,0" ColumnSpacing="8">
                <Label Grid.Column="0" Text="⌕" FontSize="18"
                       TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                <Entry Grid.Column="1"
                       Text="{Binding SearchText}"
                       Placeholder="Buscar por nombre..."
                       PlaceholderColor="{StaticResource TextPlaceholder}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent" ReturnType="Search"/>
            </Grid>
        </Border>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource GreenPrimary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Start"
                           Margin="0,32,0,0"/>

        <!-- Estado vacío -->
        <Label Grid.Row="2"
               IsVisible="{Binding IsEmpty}"
               Text="Sin clientes registrados"
               FontSize="14" TextColor="{StaticResource TextSecondary}"
               HorizontalTextAlignment="Center"
               VerticalOptions="Start"
               Margin="0,32,0,0"/>

        <!-- ── Lista de clientes ──────────────────────────────────────────── -->
        <CollectionView Grid.Row="2"
                        IsVisible="{Binding HasClients}"
                        ItemsSource="{Binding Clients}"
                        Margin="16,4,16,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ClientSummary">

                    <Border BackgroundColor="{StaticResource White}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 14"
                            Margin="0,0,0,10" Padding="14,13">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference thisPage}, Path=BindingContext.SelectClientCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">

                            <Border Grid.Column="0"
                                    BackgroundColor="{Binding AvatarColor}"
                                    StrokeThickness="0" StrokeShape="Ellipse"
                                    HeightRequest="40" WidthRequest="40"
                                    VerticalOptions="Center">
                                <Label Text="{Binding Initials}" TextColor="White"
                                       FontSize="14" FontFamily="OpenSansSemibold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontFamily="OpenSansSemibold" FontSize="15"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="{Binding Status}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" Margin="0,0,4,0"/>

                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ── Botón nuevo cliente ────────────────────────────────────────── -->
        <Grid Grid.Row="3" Padding="16,8,16,44">
            <Button Text="＋ Agregar nuevo cliente"
                    Command="{Binding AddNewClientCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource GreenPrimary}"
                    FontFamily="OpenSansSemibold" FontSize="15"
                    BorderColor="{StaticResource GreenPrimary}"
                    BorderWidth="1.5"
                    CornerRadius="28" HeightRequest="52"/>
        </Grid>

    </Grid>
</ContentPage>
