<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="HomePageRoot"
    x:Class="Paynest.Features.Cobrador.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Paynest.Features.Cobrador.ViewModels"
    x:DataType="vm:HomeViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header verde ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource GreenPrimary}" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,32,32"/>
            </Border.StrokeShape>
            <VerticalStackLayout Padding="24,52,24,22" Spacing="16">

                <!-- Saludo -->
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding Greeting}" TextColor="#B8DCC9" FontSize="14"/>
                    <Label Text="{Binding UserName}" TextColor="White"
                           FontSize="26" FontFamily="OpenSansSemibold"/>
                </VerticalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="White" HorizontalOptions="Center"/>

                <!-- Tarjetas de estadísticas -->
                <Grid ColumnDefinitions="*,10,*">
                    <!-- Cobrado hoy -->
                    <Border Grid.Column="0" BackgroundColor="#1F4F37" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="14,12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="COBRADO HOY" TextColor="#B8DCC9"
                                   FontSize="11" CharacterSpacing="0.6"/>
                            <Label Text="{Binding CobradoHoy}" TextColor="White"
                                   FontSize="24" FontFamily="OpenSansSemibold"/>
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="{Binding DeltaArrow}"
                                       TextColor="{Binding DeltaColor}"
                                       FontSize="12" FontFamily="OpenSansSemibold"/>
                                <Label Text="{Binding DeltaHoy}"
                                       TextColor="#B8DCC9" FontSize="12"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Esta semana + progress bar -->
                    <Border Grid.Column="2" BackgroundColor="#1F4F37" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="14,12">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="ESTA SEMANA" TextColor="#B8DCC9"
                                   FontSize="11" CharacterSpacing="0.6"/>
                            <Label Text="{Binding EstaSemana}" TextColor="White"
                                   FontSize="24" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding MetaSemanal}" TextColor="#B8DCC9" FontSize="12"/>
                            <!-- Progress bar de meta semanal -->
                            <ProgressBar Progress="{Binding WeeklyProgress}"
                                         ProgressColor="#4CD790"
                                         BackgroundColor="#163D28"
                                         HeightRequest="6"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ── Contenido scrollable ──────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- ── Acciones rápidas (2 rows) ─────────────────────────── -->
                <Label Text="Acciones rápidas" FontFamily="OpenSansSemibold"
                       FontSize="16" TextColor="{StaticResource TextPrimary}"
                       Margin="0,0,0,12"/>

                <!-- Fila 1: acciones primarias -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,0,0,10">
                    <!-- Nueva deuda -->
                    <Border Grid.Column="0" BackgroundColor="{StaticResource GreenPrimary}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NuevaDeudaCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Image Source="ic_debt.svg" HeightRequest="22" WidthRequest="22" VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Nueva deuda" TextColor="White"
                                       FontSize="14" FontFamily="OpenSansSemibold"/>
                                <Label Text="Crear deuda a un cliente" TextColor="#B8DCC9" FontSize="11"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Registrar pago -->
                    <Border Grid.Column="1" BackgroundColor="#EBF5EF"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RegistrarPagoCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Image Source="tab_card.svg" HeightRequest="22" WidthRequest="22" VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Registrar pago" TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" FontFamily="OpenSansSemibold"/>
                                <Label Text="Marcar cuota pagada" TextColor="{StaticResource TextSecondary}"
                                       FontSize="11"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- Fila 2: acciones secundarias -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <!-- Nuevo cliente -->
                    <Border Grid.Column="0" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AnadirClienteCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Image Source="tab_profile.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="Cliente" TextColor="{StaticResource TextPrimary}"
                                   FontSize="10" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Editar deuda -->
                    <Border Grid.Column="1" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EditarDeudaCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Image Source="ic_edit_dark.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="Editar deuda" TextColor="{StaticResource TextPrimary}"
                                   FontSize="10" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Cobros -->
                    <Border Grid.Column="2" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerCobroCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Image Source="ic_money.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="Cobros" TextColor="{StaticResource TextPrimary}"
                                   FontSize="10" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Agenda -->
                    <Border Grid.Column="3" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="8,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerAgendaCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Image Source="ic_calendar.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="Agenda" TextColor="{StaticResource TextPrimary}"
                                   FontSize="10" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── Deudas activas ─────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,24,0,12">
                    <Label Text="Deudas activas" FontFamily="OpenSansSemibold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ver clientes →"
                           TextColor="{StaticResource GreenAccent}" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerDeudasCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Grid ColumnDefinitions="*,10,*">
                    <Border Grid.Column="0" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerDeudasCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="PENDIENTE" TextColor="{StaticResource TextSecondary}"
                                       FontSize="11" CharacterSpacing="0.5" VerticalOptions="Center"/>
                                <Image Grid.Column="1" Source="ic_warning.svg" HeightRequest="16" WidthRequest="16" VerticalOptions="Center"/>
                            </Grid>
                            <Label Text="{Binding PendienteTotal}" TextColor="#E65100"
                                   FontSize="22" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding PendienteClientes}"
                                   TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="White"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerDeudasCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="VENCIDO" TextColor="{StaticResource TextSecondary}"
                                       FontSize="11" CharacterSpacing="0.5" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="🔺" FontSize="16"/>
                            </Grid>
                            <Label Text="{Binding VencidoTotal}" TextColor="{StaticResource Error}"
                                   FontSize="22" FontFamily="OpenSansSemibold"/>
                            <Label Text="{Binding VencidoClientes}"
                                   TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── Cobros de hoy ──────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,24,0,12">
                    <Label Text="Cobros de hoy" FontFamily="OpenSansSemibold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ver agenda →"
                           TextColor="{StaticResource GreenAccent}" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerAgendaCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Border IsVisible="{Binding IsTodayLoading}" BackgroundColor="White"
                        StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="18,16">
                    <ActivityIndicator IsRunning="{Binding IsTodayLoading}"
                                       Color="{StaticResource GreenPrimary}" HorizontalOptions="Center"/>
                </Border>

                <Border IsVisible="{Binding IsTodayEmpty}" BackgroundColor="White"
                        StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="18,16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Sin cobros para hoy" FontFamily="OpenSansSemibold"
                               FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="No hay cobros programados para hoy."
                               FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding HasTodayItems}"
                                     BindableLayout.ItemsSource="{Binding TodayItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:HomeTodayVisitItem">
                            <Border BackgroundColor="White" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16" Padding="14,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.AbrirCobroCommand, Source={x:Reference HomePageRoot}}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Border BackgroundColor="{Binding AvatarColor}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14" HeightRequest="44" WidthRequest="44">
                                        <Label Text="{Binding ClientInitials}" FontSize="15"
                                               FontFamily="OpenSansSemibold" TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding ClientName}" FontSize="14"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="{Binding InstallmentLabel}" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"
                                               LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="4"
                                                         HorizontalOptions="End" VerticalOptions="Center">
                                        <Label Text="{Binding AmountText}" FontSize="15"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextPrimary}"
                                               HorizontalTextAlignment="End"/>
                                        <Border BackgroundColor="{Binding StatusBg}" StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8" Padding="8,3"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding StatusLabel}" FontSize="10"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{Binding StatusFg}"/>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Label IsVisible="{Binding HasMorToday}" Text="Ver todos en agenda →"
                       TextColor="{StaticResource GreenAccent}" FontSize="13"
                       FontFamily="OpenSansSemibold" HorizontalOptions="End" Margin="0,8,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VerAgendaCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- ── Pagos recientes ────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,24,0,12">
                    <Label Text="Pagos recientes" FontFamily="OpenSansSemibold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ver historial →"
                           TextColor="{StaticResource GreenAccent}" FontSize="14" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VerCobroCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Border IsVisible="{Binding IsRecentLoading}" BackgroundColor="White"
                        StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="18,16">
                    <ActivityIndicator IsRunning="{Binding IsRecentLoading}"
                                       Color="{StaticResource GreenPrimary}" HorizontalOptions="Center"/>
                </Border>

                <Border IsVisible="{Binding IsRecentEmpty}" BackgroundColor="White"
                        StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="18,16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Sin pagos recientes" FontFamily="OpenSansSemibold"
                               FontSize="14" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Los pagos que registres aparecerán aquí."
                               FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding HasRecentItems}" BackgroundColor="White"
                        StrokeThickness="0" StrokeShape="RoundRectangle 16" Padding="14,10">
                    <VerticalStackLayout Spacing="0"
                                         BindableLayout.ItemsSource="{Binding RecentItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:HomeRecentPaymentItem">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12"
                                      Padding="2,10">
                                    <Border BackgroundColor="{Binding AvatarColor}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12" HeightRequest="40" WidthRequest="40">
                                        <Label Text="{Binding ClientInitials}" FontSize="14"
                                               FontFamily="OpenSansSemibold" TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding ClientName}" FontSize="14"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="{Binding MethodText}" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="2"
                                                         HorizontalOptions="End" VerticalOptions="Center">
                                        <Label Text="{Binding AmountText}" FontSize="15"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource GreenPrimary}"
                                               HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding TimeAgoText}" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalTextAlignment="End"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
