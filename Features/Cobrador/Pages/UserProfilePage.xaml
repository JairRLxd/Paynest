<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Cobrador.Pages.UserProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource AppBgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ───────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource GreenPrimary}, Dark={StaticResource AppSurfaceDark}}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,28,28"/>
            </Border.StrokeShape>
            <VerticalStackLayout Padding="24,56,24,28" Spacing="14" HorizontalOptions="Center">

                <!-- Avatar: selfie cuando está disponible, iniciales si no -->
                <Grid HorizontalOptions="Center"
                      HeightRequest="72" WidthRequest="72">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                    </Grid.GestureRecognizers>

                    <!-- Iniciales (fondo siempre presente) -->
                    <Border x:Name="AvatarBorder"
                            HeightRequest="72" WidthRequest="72"
                            BackgroundColor="#1D4D38"
                            StrokeThickness="0" StrokeShape="Ellipse">
                        <Label x:Name="InitialsLabel"
                               Text="??"
                               TextColor="White"
                               FontSize="26"
                               FontFamily="OpenSansSemibold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Foto selfie (encima cuando hay URL) -->
                    <Border x:Name="SelfieAvatarBorder"
                            IsVisible="False"
                            HeightRequest="72" WidthRequest="72"
                            BackgroundColor="Transparent"
                            StrokeThickness="2"
                            Stroke="#2A6349"
                            StrokeShape="Ellipse">
                        <Image x:Name="SelfieImage"
                               Aspect="AspectFill"
                               HeightRequest="72"
                               WidthRequest="72"/>
                    </Border>

                    <!-- Badge editar -->
                    <Border BackgroundColor="#2A6349"
                            StrokeThickness="0"
                            StrokeShape="Ellipse"
                            HeightRequest="22" WidthRequest="22"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Margin="0,0,2,2">
                        <Image Source="ic_edit.svg" HeightRequest="12" WidthRequest="12"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Nombre, email, badge de rol -->
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label x:Name="FullNameLabel"
                           Text=""
                           TextColor="White"
                           FontSize="20"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center"/>
                    <Label x:Name="EmailLabel"
                           Text=""
                           TextColor="#B8DCC9"
                           FontSize="13"
                           HorizontalOptions="Center"/>
                    <Border x:Name="RoleBadge"
                            BackgroundColor="#1D4D38"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,4"
                            HorizontalOptions="Center"
                            Margin="0,4,0,0">
                        <Label x:Name="RoleLabel"
                               Text=""
                               TextColor="{StaticResource GreenAccent}"
                               FontSize="11"
                               FontFamily="OpenSansSemibold"
                               CharacterSpacing="1"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <!-- ── Contenido ─────────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,20,24,40" Spacing="0">

                <!-- CUENTA -->
                <Label Text="CUENTA"
                       FontFamily="OpenSansSemibold" FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                       CharacterSpacing="1.2"
                       Margin="4,0,0,8"/>

                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource AppSurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource InputBorderBrush}, Dark={StaticResource AppBorderDark}}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="1"
                        Padding="0"
                        Margin="0,0,0,20">
                    <VerticalStackLayout>

                        <!-- Email -->
                        <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Correo electrónico"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"/>
                                <Label x:Name="EmailRowLabel"
                                       Text=""
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource AppTextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource AppBorderDark}}"
                                 Margin="18,0"/>

                        <!-- Rol -->
                        <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                            <Label Grid.Column="0"
                                   Text="Rol"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource AppTextPrimaryDark}}"/>
                            <Label x:Name="RoleRowLabel"
                                   Grid.Column="1"
                                   Text=""
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- PERFIL -->
                <Label Text="PERFIL"
                       FontFamily="OpenSansSemibold" FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                       CharacterSpacing="1.2"
                       Margin="4,0,0,8"/>

                <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource AppSurfaceDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource InputBorderBrush}, Dark={StaticResource AppBorderDark}}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="1"
                        Padding="0"
                        Margin="0,0,0,20">
                    <VerticalStackLayout>

                        <!-- Datos personales -->
                        <Grid ColumnDefinitions="*,Auto" Padding="18,18">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditOnboardingTapped"/>
                            </Grid.GestureRecognizers>
                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                <Label Text="Información del perfil"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource AppTextPrimaryDark}}"/>
                                <Label Text="Nombre visible, teléfono, dirección y negocio"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                       LineHeight="1.3"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="›" FontSize="24"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource AppBorderDark}}"
                                 Margin="18,0"/>

                        <!-- Documentos de identidad -->
                        <Grid ColumnDefinitions="*,Auto" Padding="18,18">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditIdentityTapped"/>
                            </Grid.GestureRecognizers>
                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                <Label Text="Documentos de identidad"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource AppTextPrimaryDark}}"/>
                                <Label Text="INE, selfie y comprobante de domicilio"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                       LineHeight="1.3"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="›" FontSize="24"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource AppBorderDark}}"
                                 Margin="18,0"/>

                        <!-- Métodos de cobro -->
                        <Grid ColumnDefinitions="*,Auto" Padding="18,18">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditPaymentTapped"/>
                            </Grid.GestureRecognizers>
                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                <Label Text="Métodos de cobro"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource AppTextPrimaryDark}}"/>
                                <Label Text="Efectivo, transferencia y terminal"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                       LineHeight="1.3"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="›" FontSize="24"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- SESIÓN -->
                <Label Text="SESIÓN"
                       FontFamily="OpenSansSemibold" FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource AppTextSecondaryDark}}"
                       CharacterSpacing="1.2"
                       Margin="4,0,0,8"/>

                <Button Text="Cerrar sesión"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="{AppThemeBinding Light=#FFF1F3, Dark=#2D1A1D}"
                        BorderColor="#F04438"
                        BorderWidth="1.5"
                        TextColor="#D92D20"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        CornerRadius="18"
                        HeightRequest="54"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
