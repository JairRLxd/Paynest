<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="Paynest.QrScannerPage"
             Title="Escanear QR"
             BackgroundColor="#000000">
    <Grid RowDefinitions="*,Auto">
        <zxing:CameraBarcodeReaderView
            x:Name="CameraView"
            Grid.Row="0"
            IsDetecting="True"
            BarcodesDetected="OnBarcodesDetected" />

        <Grid Grid.Row="0" InputTransparent="True">
            <Grid RowDefinitions="*,260,*" ColumnDefinitions="*,260,*">
                <BoxView Grid.Row="0" Grid.ColumnSpan="3" Color="#66000000" />
                <BoxView Grid.Row="1" Grid.Column="0" Color="#66000000" />
                <BoxView Grid.Row="1" Grid.Column="2" Color="#66000000" />
                <BoxView Grid.Row="2" Grid.ColumnSpan="3" Color="#66000000" />

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Stroke="#CCFFFFFF"
                    StrokeThickness="2"
                    BackgroundColor="#0DFFFFFF"
                    StrokeShape="RoundRectangle 20">
                    <Grid>
                        <Border
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            WidthRequest="34"
                            HeightRequest="34"
                            Margin="10"
                            Stroke="{StaticResource AppAccent}"
                            StrokeThickness="4"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12" />
                        <Border
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            WidthRequest="34"
                            HeightRequest="34"
                            Margin="10"
                            Stroke="{StaticResource AppAccent}"
                            StrokeThickness="4"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12" />
                        <Border
                            HorizontalOptions="Start"
                            VerticalOptions="End"
                            WidthRequest="34"
                            HeightRequest="34"
                            Margin="10"
                            Stroke="{StaticResource AppAccent}"
                            StrokeThickness="4"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12" />
                        <Border
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            WidthRequest="34"
                            HeightRequest="34"
                            Margin="10"
                            Stroke="{StaticResource AppAccent}"
                            StrokeThickness="4"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12" />
                    </Grid>
                </Border>
            </Grid>

            <VerticalStackLayout
                VerticalOptions="End"
                HorizontalOptions="Center"
                Spacing="4"
                Margin="24,0,24,110">
                <Label
                    Text="Alinea el QR dentro del marco"
                    FontFamily="OpenSansSemibold"
                    FontSize="15"
                    HorizontalTextAlignment="Center"
                    TextColor="White" />
                <Label
                    Text="El escaneo se realiza automáticamente"
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    TextColor="#DDFFFFFF" />
            </VerticalStackLayout>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="16"
            Padding="14"
            BackgroundColor="#CC000000"
            Stroke="#33FFFFFF"
            StrokeShape="RoundRectangle 14">
            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Apunta al código QR del cobrador"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    TextColor="White" />
                <Label
                    Text="Se detectará automáticamente."
                    FontSize="13"
                    TextColor="#D8D8D8" />
                <Button
                    Text="Cancelar"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#1F1F1F"
                    TextColor="White" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
