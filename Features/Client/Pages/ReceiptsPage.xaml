<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:local="clr-namespace:Paynest"
			 xmlns:vm="clr-namespace:Paynest.Features.Client.ViewModels"
			 x:Class="Paynest.ReceiptsPage"
			 Title="Recibos"
			 BackgroundColor="{StaticResource AppBg}">
	<ContentPage.Resources>
		<Style x:Key="ReceiptPrimaryButton" TargetType="Button">
			<Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppAccent}, Dark={StaticResource AppAccentDark}}" />
			<Setter Property="BorderWidth" Value="0" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="FontFamily" Value="OpenSansSemibold" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="HeightRequest" Value="46" />
			<Setter Property="Padding" Value="14,9" />
			<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource AppBgDark}}" />
		</Style>
		<Style x:Key="ReceiptSecondaryButton" TargetType="Button">
			<Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource AppSurfaceAlt}, Dark={StaticResource AppBorderDark}}" />
			<Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}" />
			<Setter Property="BorderWidth" Value="1" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="FontFamily" Value="OpenSansSemibold" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="HeightRequest" Value="44" />
			<Setter Property="Padding" Value="10,8" />
			<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimary}, Dark={StaticResource AppTextPrimaryDark}}" />
		</Style>
	</ContentPage.Resources>
	<Grid x:Name="RootLayout" Padding="{StaticResource PagePadding}" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="{StaticResource Space16}">
		<Label Grid.Row="0" Style="{StaticResource AppPageTitle}" Text="Recibos descargables" SemanticProperties.HeadingLevel="Level1" />
		<Label Grid.Row="1" Style="{StaticResource AppCaption}" Text="{Binding GroupText}" />
		<local:NetworkBannerView
			Grid.Row="2"
			IsVisible="False"
			TitleText="No pudimos conectar con la API."
			MessageText="Desliza para actualizar.">
			<local:NetworkBannerView.Triggers>
				<DataTrigger TargetType="local:NetworkBannerView" Binding="{Binding State}" Value="{x:Static vm:ScreenState.Error}">
					<Setter Property="IsVisible" Value="True" />
				</DataTrigger>
			</local:NetworkBannerView.Triggers>
		</local:NetworkBannerView>

		<local:PageStateContainer Grid.Row="3" State="{Binding State}" VerticalOptions="FillAndExpand">
			<local:PageStateContainer.LoadingContent>
				<VerticalStackLayout Spacing="{StaticResource Space12}">
					<ActivityIndicator IsRunning="True" Color="{StaticResource AppAccent}" HorizontalOptions="Center" />
					<local:ReceiptSkeletonView />
				</VerticalStackLayout>
			</local:PageStateContainer.LoadingContent>

			<local:PageStateContainer.ContentBody>
				<RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}" VerticalOptions="FillAndExpand">
					<CollectionView
						ItemsSource="{Binding ReceiptSections}"
						IsGrouped="True"
						SelectionMode="None"
						SemanticProperties.Description="Lista de recibos descargables"
						VerticalOptions="FillAndExpand"
						Margin="0,8,0,0">
						<CollectionView.ItemsLayout>
							<LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
						</CollectionView.ItemsLayout>
						<CollectionView.GroupHeaderTemplate>
							<DataTemplate>
								<local:SectionHeaderView TitleText="{Binding Title}" MetaText="{Binding CountText}" />
							</DataTemplate>
						</CollectionView.GroupHeaderTemplate>
						<CollectionView.ItemTemplate>
							<DataTemplate>
								<Border Style="{StaticResource AppCardBorder}" Margin="0">
									<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">
										<Label FontAttributes="Bold" FontSize="17" Text="{Binding Title}" LineBreakMode="TailTruncation" />
										<Label Grid.Column="1" Style="{StaticResource AppAmountText}" Text="{Binding AmountText}" LineBreakMode="TailTruncation" />
										<Label Grid.Row="1" Style="{StaticResource AppCaption}" Text="{Binding PaidDateText}" />
										<Label Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource AppCaption}" Text="{Binding FolioText}" />
										<VerticalStackLayout
											Grid.Row="3"
											Grid.ColumnSpan="2"
											Margin="0,10,0,0"
											Spacing="8">
											<Button
												Style="{StaticResource ReceiptPrimaryButton}"
												Text="Ver recibo"
												SemanticProperties.Description="Abrir este recibo"
												Clicked="OnViewReceiptClicked"
												CommandParameter="{Binding Id}" />
											<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
												<Button
													Style="{StaticResource ReceiptSecondaryButton}"
													Text="Compartir"
													SemanticProperties.Description="Compartir este recibo"
													Clicked="OnShareReceiptClicked"
													CommandParameter="{Binding Id}" />
												<Button
													Grid.Column="1"
													Style="{StaticResource ReceiptSecondaryButton}"
													Text="Descargar"
													SemanticProperties.Description="Descargar este recibo"
													Clicked="OnDownloadReceiptClicked"
													CommandParameter="{Binding Id}" />
											</Grid>
										</VerticalStackLayout>
									</Grid>
								</Border>
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>
				</RefreshView>
			</local:PageStateContainer.ContentBody>

			<local:PageStateContainer.EmptyContent>
				<local:EmptyStateView
					IconSource="tab_receipt.svg"
					TitleText="Aún no hay recibos"
					DescriptionText="Cuando confirmes pagos, podrás abrir, compartir o descargar sus comprobantes aquí."
					ActionText="Actualizar ahora"
					ActionCommand="{Binding RefreshCommand}" />
			</local:PageStateContainer.EmptyContent>

			<local:PageStateContainer.ErrorContent>
				<local:ErrorCardView ErrorMessage="{Binding ErrorMessage}" RetryCommand="{Binding RetryCommand}" />
			</local:PageStateContainer.ErrorContent>
		</local:PageStateContainer>
	</Grid>
</ContentPage>
