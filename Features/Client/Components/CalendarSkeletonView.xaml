<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Paynest"
             x:Class="Paynest.CalendarSkeletonView">
    <VerticalStackLayout Spacing="{StaticResource Space12}">
        <BoxView HeightRequest="18" WidthRequest="120" CornerRadius="8" Color="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}" />
        <local:SkeletonCardView />
        <BoxView HeightRequest="18" WidthRequest="150" CornerRadius="8" Color="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}" />
        <local:SkeletonCardView />
    </VerticalStackLayout>
</ContentView>
