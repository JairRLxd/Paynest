<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Paynest"
             x:Class="Paynest.StatusBadgeView">
    <Border Padding="0"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 10"
            BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type local:StatusBadgeView}}, Path=BadgeBackground}">
        <Label Style="{StaticResource AppBadgeText}"
               TextColor="{Binding Source={RelativeSource AncestorType={x:Type local:StatusBadgeView}}, Path=BadgeForeground}">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="{Binding Source={RelativeSource AncestorType={x:Type local:StatusBadgeView}}, Path=BadgeIcon}" />
                    <Span Text=" " />
                    <Span Text="{Binding Source={RelativeSource AncestorType={x:Type local:StatusBadgeView}}, Path=BadgeText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>
    </Border>
</ContentView>
