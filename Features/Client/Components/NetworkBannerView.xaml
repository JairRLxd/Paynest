<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Paynest"
             x:Class="Paynest.NetworkBannerView">
    <Border
        BackgroundColor="{StaticResource DangerBg}"
        Stroke="{StaticResource DangerFg}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12"
        Padding="12,10">
        <HorizontalStackLayout Spacing="8">
            <Label
                Text="{Binding Source={RelativeSource AncestorType={x:Type local:NetworkBannerView}}, Path=TitleText}"
                TextColor="{StaticResource DangerFg}"
                FontAttributes="Bold" />
            <Label
                Text="{Binding Source={RelativeSource AncestorType={x:Type local:NetworkBannerView}}, Path=MessageText}"
                TextColor="{StaticResource DangerFg}" />
        </HorizontalStackLayout>
    </Border>
</ContentView>
