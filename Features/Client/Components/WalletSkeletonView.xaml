<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Paynest"
             x:Class="Paynest.WalletSkeletonView">
    <VerticalStackLayout Spacing="{StaticResource Space12}">
        <Border StrokeThickness="0" StrokeShape="RoundRectangle 18" BackgroundColor="{StaticResource AppSurfaceAlt}" Padding="18">
            <VerticalStackLayout Spacing="14">
                <BoxView HeightRequest="14" WidthRequest="130" CornerRadius="7" Color="#D8E9DE" />
                <BoxView HeightRequest="32" WidthRequest="190" CornerRadius="10" Color="#D8E9DE" />
                <BoxView HeightRequest="12" WidthRequest="150" CornerRadius="6" Color="#D8E9DE" />
            </VerticalStackLayout>
        </Border>
        <Border Style="{StaticResource AppCardBorder}" Margin="{StaticResource CardItemMargin}">
            <VerticalStackLayout Spacing="10">
                <BoxView HeightRequest="14" WidthRequest="135" CornerRadius="7" Color="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}" />
                <BoxView HeightRequest="18" WidthRequest="210" CornerRadius="8" Color="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}" />
                <BoxView HeightRequest="12" WidthRequest="170" CornerRadius="6" Color="{AppThemeBinding Light={StaticResource AppBorder}, Dark={StaticResource AppBorderDark}}" />
            </VerticalStackLayout>
        </Border>
        <local:SkeletonCardView ShowButton="True" />
    </VerticalStackLayout>
</ContentView>
