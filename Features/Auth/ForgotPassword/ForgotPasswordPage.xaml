<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Paynest.Features.Auth.ForgotPassword.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Paynest.Features.Auth.ForgotPassword"
    x:DataType="vm:ForgotPasswordViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="28,52,28,24" Spacing="0">

                <!-- Logo -->
                <HorizontalStackLayout Spacing="12" Margin="0,0,0,6">
                    <Image
                        Source="paynest_icon.png"
                        HeightRequest="52"
                        WidthRequest="52"
                        Aspect="AspectFit"
                        VerticalOptions="Center"/>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                        <Label
                            Text="Paynest."
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="26"
                            FontFamily="OpenSansSemibold"/>
                        <Label
                            Text="COBROS · CARTERA · CONTROL"
                            TextColor="{StaticResource GreenAccent}"
                            FontSize="10"
                            CharacterSpacing="1.2"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Subtítulo -->
                <Label
                    Text="Recupera tu acceso en segundos."
                    TextColor="{StaticResource TextSecondary}"
                    FontSize="15"
                    LineHeight="1.45"
                    Margin="0,16,0,22"/>

                <BoxView
                    HeightRequest="1"
                    BackgroundColor="{StaticResource Divider}"
                    Margin="0,0,0,28"/>

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- PASO 1: Ingresar email                                -->
                <!-- ══════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="0">

                    <Label
                        Text="Recuperar contraseña"
                        TextColor="{StaticResource TextPrimary}"
                        FontSize="20"
                        FontFamily="OpenSansSemibold"
                        Margin="0,0,0,6"/>

                    <Label
                        Text="Ingresa el correo de tu cuenta y te enviaremos un código de verificación."
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="14"
                        LineHeight="1.4"
                        Margin="0,0,0,24"/>

                    <Label
                        Text="Correo electrónico"
                        FontSize="14"
                        FontFamily="OpenSansSemibold"
                        TextColor="{StaticResource TextPrimary}"
                        Margin="0,0,0,6"/>

                    <Border
                        Stroke="{StaticResource InputBorderBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        BackgroundColor="{StaticResource White}"
                        HeightRequest="52">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding HasEmailError}"
                                         Value="True">
                                <Setter Property="Stroke" Value="{StaticResource ErrorBrush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Entry
                            Placeholder="tu@correo.mx"
                            Text="{Binding Email, Mode=TwoWay}"
                            Keyboard="Email"
                            IsTextPredictionEnabled="False"
                            IsSpellCheckEnabled="False"
                            TextTransform="None"
                            ClearButtonVisibility="WhileEditing"
                            BackgroundColor="Transparent"
                            PlaceholderColor="{StaticResource TextPlaceholder}"
                            TextColor="{StaticResource TextPrimary}"
                            Margin="8,0"
                            ReturnType="Go"
                            ReturnCommand="{Binding RequestCodeCommand}"/>
                    </Border>

                    <HorizontalStackLayout
                        IsVisible="{Binding HasEmailError}"
                        Spacing="4"
                        Margin="2,5,0,0">
                        <Label Text="⚠" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                        <Label Text="{Binding EmailError}" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Error general -->
                    <Border
                        IsVisible="{Binding HasGeneralError}"
                        BackgroundColor="#FFF5F5"
                        Stroke="#FFCDD2"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Margin="0,16,0,0">
                        <Label
                            Text="{Binding GeneralError}"
                            TextColor="{StaticResource Error}"
                            FontSize="13"
                            Padding="14,10"/>
                    </Border>

                    <Button
                        Text="Enviar código  →"
                        Command="{Binding RequestCodeCommand}"
                        IsEnabled="{Binding IsNotLoading}"
                        BackgroundColor="{StaticResource GreenPrimary}"
                        TextColor="{StaticResource White}"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        CornerRadius="28"
                        HeightRequest="56"
                        HorizontalOptions="Fill"
                        Margin="0,22,0,0"/>

                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- PASO 2: Ingresar código + nueva contraseña            -->
                <!-- ══════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsStep2}" Spacing="0">

                    <Label
                        Text="Crea una nueva contraseña"
                        TextColor="{StaticResource TextPrimary}"
                        FontSize="20"
                        FontFamily="OpenSansSemibold"
                        Margin="0,0,0,6"/>

                    <Label
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="14"
                        LineHeight="1.4"
                        Margin="0,0,0,24">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Revisaste tu correo "/>
                                <Span Text="{Binding Email}" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextPrimary}"/>
                                <Span Text=" y ahora ingresa el código junto con tu nueva contraseña."/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <!-- Código -->
                    <Label
                        Text="Código de verificación"
                        FontSize="14"
                        FontFamily="OpenSansSemibold"
                        TextColor="{StaticResource TextPrimary}"
                        Margin="0,0,0,6"/>

                    <Border
                        Stroke="{StaticResource InputBorderBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        BackgroundColor="{StaticResource White}"
                        HeightRequest="52">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding HasCodeError}"
                                         Value="True">
                                <Setter Property="Stroke" Value="{StaticResource ErrorBrush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Entry
                            Placeholder="Código recibido por email"
                            Text="{Binding Code, Mode=TwoWay}"
                            Keyboard="Default"
                            IsTextPredictionEnabled="False"
                            IsSpellCheckEnabled="False"
                            TextTransform="Uppercase"
                            ClearButtonVisibility="WhileEditing"
                            BackgroundColor="Transparent"
                            PlaceholderColor="{StaticResource TextPlaceholder}"
                            TextColor="{StaticResource TextPrimary}"
                            Margin="8,0"
                            ReturnType="Next"/>
                    </Border>

                    <HorizontalStackLayout
                        IsVisible="{Binding HasCodeError}"
                        Spacing="4"
                        Margin="2,5,0,16">
                        <Label Text="⚠" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                        <Label Text="{Binding CodeError}" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Nueva contraseña -->
                    <Label
                        Text="Nueva contraseña"
                        FontSize="14"
                        FontFamily="OpenSansSemibold"
                        TextColor="{StaticResource TextPrimary}"
                        Margin="0,16,0,6"/>

                    <Border
                        Stroke="{StaticResource InputBorderBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        BackgroundColor="{StaticResource White}"
                        HeightRequest="52">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding HasNewPasswordError}"
                                         Value="True">
                                <Setter Property="Stroke" Value="{StaticResource ErrorBrush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="*, 44" Padding="8,0,0,0">
                            <Entry
                                Grid.Column="0"
                                Placeholder="Mínimo 12 caracteres"
                                Text="{Binding NewPassword}"
                                IsPassword="{Binding IsPasswordHidden}"
                                BackgroundColor="Transparent"
                                PlaceholderColor="{StaticResource TextPlaceholder}"
                                TextColor="{StaticResource TextPrimary}"
                                ReturnType="Next"/>
                            <ImageButton
                                Grid.Column="1"
                                Source="{Binding EyeIconSource}"
                                Command="{Binding TogglePasswordCommand}"
                                HeightRequest="22"
                                WidthRequest="22"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <HorizontalStackLayout
                        IsVisible="{Binding HasNewPasswordError}"
                        Spacing="4"
                        Margin="2,5,0,0">
                        <Label Text="⚠" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                        <Label Text="{Binding NewPasswordError}" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Confirmar contraseña -->
                    <Label
                        Text="Confirmar contraseña"
                        FontSize="14"
                        FontFamily="OpenSansSemibold"
                        TextColor="{StaticResource TextPrimary}"
                        Margin="0,18,0,6"/>

                    <Border
                        Stroke="{StaticResource InputBorderBrush}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        BackgroundColor="{StaticResource White}"
                        HeightRequest="52">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding HasPasswordConfirmError}"
                                         Value="True">
                                <Setter Property="Stroke" Value="{StaticResource ErrorBrush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="*, 44" Padding="8,0,0,0">
                            <Entry
                                Grid.Column="0"
                                Placeholder="Repite tu nueva contraseña"
                                Text="{Binding PasswordConfirm}"
                                IsPassword="{Binding IsPasswordConfirmHidden}"
                                BackgroundColor="Transparent"
                                PlaceholderColor="{StaticResource TextPlaceholder}"
                                TextColor="{StaticResource TextPrimary}"
                                ReturnType="Go"
                                ReturnCommand="{Binding ResetPasswordCommand}"/>
                            <ImageButton
                                Grid.Column="1"
                                Source="{Binding EyeConfirmIconSource}"
                                Command="{Binding TogglePasswordConfirmCommand}"
                                HeightRequest="22"
                                WidthRequest="22"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <HorizontalStackLayout
                        IsVisible="{Binding HasPasswordConfirmError}"
                        Spacing="4"
                        Margin="2,5,0,0">
                        <Label Text="⚠" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                        <Label Text="{Binding PasswordConfirmError}" TextColor="{StaticResource Error}" FontSize="12" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Error general -->
                    <Border
                        IsVisible="{Binding HasGeneralError}"
                        BackgroundColor="#FFF5F5"
                        Stroke="#FFCDD2"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Margin="0,16,0,0">
                        <Label
                            Text="{Binding GeneralError}"
                            TextColor="{StaticResource Error}"
                            FontSize="13"
                            Padding="14,10"/>
                    </Border>

                    <!-- Éxito -->
                    <Border
                        IsVisible="{Binding HasSuccess}"
                        BackgroundColor="#EBF5EF"
                        Stroke="#A7D7BB"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Margin="0,16,0,0">
                        <Label
                            Text="{Binding SuccessMessage}"
                            TextColor="{StaticResource GreenPrimary}"
                            FontSize="13"
                            Padding="14,10"/>
                    </Border>

                    <Button
                        Text="Cambiar contraseña  →"
                        Command="{Binding ResetPasswordCommand}"
                        IsEnabled="{Binding IsNotLoading}"
                        BackgroundColor="{StaticResource GreenPrimary}"
                        TextColor="{StaticResource White}"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        CornerRadius="28"
                        HeightRequest="56"
                        HorizontalOptions="Fill"
                        Margin="0,22,0,0"/>

                </VerticalStackLayout>

                <!-- Cargando -->
                <ActivityIndicator
                    IsVisible="{Binding IsLoading}"
                    IsRunning="{Binding IsLoading}"
                    Color="{StaticResource GreenPrimary}"
                    HorizontalOptions="Center"
                    Margin="0,24,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer: volver al login -->
        <HorizontalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="4"
            Margin="0,0,0,36">
            <Label
                Text="¿Ya recordaste?"
                TextColor="{StaticResource TextSecondary}"
                FontSize="14"/>
            <Label
                Text="Iniciar sesión"
                TextColor="{StaticResource GreenAccent}"
                FontSize="14"
                FontFamily="OpenSansSemibold">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoToLoginTapped"/>
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

    </Grid>
</ContentPage>
